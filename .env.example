# ==========================================
# AmoPagar Environment Variables Template
# ==========================================
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your actual values below
# 3. Never commit .env.local to git (it's in .gitignore)
# 4. For production: Add these to Vercel Dashboard → Settings → Environment Variables
#
# IMPORTANT: All NEXT_PUBLIC_ variables are exposed to the browser
# Keep service keys and secrets PRIVATE (no NEXT_PUBLIC_ prefix)
# ==========================================

# ==========================================
# ✅ REQUIRED - Supabase Configuration
# ==========================================
# Get these from: https://app.supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==========================================
# ✅ REQUIRED - Stripe Configuration
# ==========================================
# Get these from: https://dashboard.stripe.com/test/apikeys
# For production, switch to live keys (remove _test_)
STRIPE_SECRET_KEY=sk_test_51xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51xxxxxxxxxxxxx

# Webhook secret (optional for local dev, required for production)
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# ==========================================
# ✅ REQUIRED - NextAuth Configuration
# ==========================================
# Generate secret: https://generate-secret.vercel.app/32
# Or run: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-32-character-secret-here

# Local development:
NEXTAUTH_URL=http://localhost:3000

# Production (Vercel auto-sets this, but you can override):
# NEXTAUTH_URL=https://your-domain.vercel.app
# Or for custom domain:
# NEXTAUTH_URL=https://amopagar.com.br

# ==========================================
# ⚙️ OPTIONAL - Google OAuth (for client login)
# ==========================================
# Get these from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID → Web application
# Add authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=123456789-xxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# ==========================================
# ⚙️ OPTIONAL - Twilio SMS (if using custom SMS provider)
# ==========================================
# Note: Supabase handles SMS by default, only use if customizing
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+5511999999999

# ==========================================
# ⚙️ OPTIONAL - Resend Email (for receipt emails)
# ==========================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@amopagar.com

# ==========================================
# ⚙️ OPTIONAL - Sentry Error Monitoring
# ==========================================
# Get from: https://sentry.io → Your Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=amopagar
# Auth token for source map uploads (CI only): https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=

# ==========================================
# ⚙️ OPTIONAL - App Configuration
# ==========================================
# Used for generating links in emails, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production:
# NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ==========================================
# 📝 SETUP CHECKLIST
# ==========================================
# Local Development:
# [ ] Copy this file to .env.local
# [ ] Fill in Supabase credentials (test project)
# [ ] Fill in Stripe test keys
# [ ] Generate NEXTAUTH_SECRET: openssl rand -base64 32
# [ ] (Optional) Add Google OAuth credentials
# [ ] Run: npm run dev
#
# Production (Self-hosted server):
# [ ] Copy this file to .env.production on the server
# [ ] Fill in production Supabase credentials
# [ ] Switch Stripe to live keys (sk_live_... / pk_live_...)
# [ ] Set NEXTAUTH_URL=https://yourdomain.com
# [ ] Set NEXT_PUBLIC_APP_URL=https://yourdomain.com
# [ ] Configure Google OAuth production redirect URIs
# [ ] See DEPLOYMENT_CHECKLIST.md for full server setup
#
# ==========================================
# 🔗 HELPFUL LINKS
# ==========================================
# Supabase Dashboard: https://app.supabase.com
# Stripe Dashboard: https://dashboard.stripe.com
# Google Console: https://console.cloud.google.com
# Vercel Dashboard: https://vercel.com/dashboard
# Generate Secret: https://generate-secret.vercel.app/32
#
# Documentation: See AUTHENTICATION_GUIDE.md
